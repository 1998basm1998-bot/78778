import React, { useState, useEffect, useMemo } from 'react';
import { 
  Package, Users, PlusCircle, CheckCircle, Clock, Truck, 
  Trash2, MapPin, Phone, User, DollarSign, XCircle, FileText, Check, Plus, Tag, ImagePlus,
  Settings, Download, Upload, Moon, Sun, Lock, Key, Unlock, Eye, EyeOff, ShoppingCart, Minus, MinusCircle, PieChart, CheckCircle2, Save, X, Pencil, ArrowRight
} from 'lucide-react';
import { Order, OrderStatus, Product, Customer, Category, OrderItem } from './types';
import { usePDF } from 'react-to-pdf';

const STORAGE_KEY_ORDERS = 'mandoob_orders_v1';
const STORAGE_KEY_PRODUCTS = 'mandoob_products_v1';
const STORAGE_KEY_CUSTOMERS = 'mandoob_customers_v1';
const STORAGE_KEY_CATEGORIES = 'mandoob_categories_v1';
const STORAGE_KEY_PASSWORD = 'mandoob_password_v1';
const STORAGE_KEY_THEME = 'mandoob_theme_v1';

type Tab = 'products' | 'customers' | 'new_order' | 'settings';

export default function App() {
  const [activeTab, setActiveTab] = useState<Tab>('products');
  const [showAddProduct, setShowAddProduct] = useState(false);
  const [confirmDialog, setConfirmDialog] = useState<{isOpen: boolean, message: string, onConfirm: () => void} | null>(null);
  const [alertDialog, setAlertDialog] = useState<{isOpen: boolean, message: string} | null>(null);
  
  // App Settings
  const [theme, setTheme] = useState<'light' | 'dark'>(() => (localStorage.getItem(STORAGE_KEY_THEME) as 'light' | 'dark') || 'light');
  const [password, setPassword] = useState(() => localStorage.getItem(STORAGE_KEY_PASSWORD) || '');
  const [isAuthenticated, setIsAuthenticated] = useState(() => !localStorage.getItem(STORAGE_KEY_PASSWORD));
  const [loginPassword, setLoginPassword] = useState('');
  const [loginError, setLoginError] = useState('');
  const [newPassword, setNewPassword] = useState('');
  const [showLoginPassword, setShowLoginPassword] = useState(false);
  const [showNewPassword, setShowNewPassword] = useState(false);

  // Persistence State
  const [orders, setOrders] = useState<Order[]>(() => {
    if (typeof window !== 'undefined') {
      const saved = localStorage.getItem(STORAGE_KEY_ORDERS);
      if (saved) return JSON.parse(saved);
    }
    return [];
  });

  const [products, setProducts] = useState<Product[]>(() => {
    if (typeof window !== 'undefined') {
      const saved = localStorage.getItem(STORAGE_KEY_PRODUCTS);
      if (saved) return JSON.parse(saved);
    }
    return [];
  });

  const [deferredPrompt, setDeferredPrompt] = useState<any>(null);
  const [isInstallable, setIsInstallable] = useState(false);
  const [showIosInstallPrompt, setShowIosInstallPrompt] = useState(false);
  const [showIosInstructionsModal, setShowIosInstructionsModal] = useState(false);

  useEffect(() => {
    // Check if it's iOS
    const isIos = () => {
      const userAgent = window.navigator.userAgent.toLowerCase();
      return /iphone|ipad|ipod/.test(userAgent);
    };
    
    // Check if it's already installed (standalone mode)
    const isInStandaloneMode = () => ('standalone' in window.navigator) && (window.navigator as any).standalone;

    if (isIos() && !isInStandaloneMode()) {
      setShowIosInstallPrompt(true);
    }

    const handleBeforeInstallPrompt = (e: any) => {
      e.preventDefault();
      setDeferredPrompt(e);
      setIsInstallable(true);
    };

    window.addEventListener('beforeinstallprompt', handleBeforeInstallPrompt);

    return () => {
      window.removeEventListener('beforeinstallprompt', handleBeforeInstallPrompt);
    };
  }, []);

  const handleInstallClick = async () => {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    if (outcome === 'accepted') {
      setDeferredPrompt(null);
      setIsInstallable(false);
    }
  };

  const [categories, setCategories] = useState<Category[]>(() => {
    if (typeof window !== 'undefined') {
      const saved = localStorage.getItem(STORAGE_KEY_CATEGORIES);
      if (saved) return JSON.parse(saved);
    }
    return [];
  });

  const [customers, setCustomers] = useState<Customer[]>(() => {
    if (typeof window !== 'undefined') {
      const saved = localStorage.getItem(STORAGE_KEY_CUSTOMERS);
      if (saved) return JSON.parse(saved);
    }
    return [];
  });

  // Theme Effect
  useEffect(() => {
    localStorage.setItem(STORAGE_KEY_THEME, theme);
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }, [theme]);

  // Save to LocalStorage on changes
  useEffect(() => {
    try {
      localStorage.setItem(STORAGE_KEY_ORDERS, JSON.stringify(orders));
    } catch (e) {
      console.error("Failed to save orders", e);
    }
  }, [orders]);

  useEffect(() => {
    try {
      localStorage.setItem(STORAGE_KEY_PRODUCTS, JSON.stringify(products));
    } catch (e) {
      console.error("Failed to save products", e);
      if (e instanceof Error && e.name === 'QuotaExceededError') {
        alert('مساحة التخزين ممتلئة. يرجى حذف بعض المنتجات القديمة أو تقليل حجم الصور.');
      }
    }
  }, [products]);

  useEffect(() => {
    try {
      localStorage.setItem(STORAGE_KEY_CUSTOMERS, JSON.stringify(customers));
    } catch (e) {
      console.error("Failed to save customers", e);
    }
  }, [customers]);

  useEffect(() => {
    try {
      localStorage.setItem(STORAGE_KEY_CATEGORIES, JSON.stringify(categories));
    } catch (e) {
      console.error("Failed to save categories", e);
    }
  }, [categories]);

  // Form States - Products
  const [productName, setProductName] = useState('');
  const [productSellPrice, setProductSellPrice] = useState('');
  const [productPurchasePrice, setProductPurchasePrice] = useState('');
  const [productDescription, setProductDescription] = useState('');
  const [productImage, setProductImage] = useState('');
  const [productCategory, setProductCategory] = useState('');
  const [editingProduct, setEditingProduct] = useState<string | null>(null);

  // Form States - Categories
  const [showAddCategory, setShowAddCategory] = useState(false);
  const [categoryName, setCategoryName] = useState('');
  const [editingCategory, setEditingCategory] = useState<string | null>(null);

  // Form States - Customers
  const [customerName, setCustomerName] = useState('');
  const [customerPhone, setCustomerPhone] = useState('');
  const [customerAddress, setCustomerAddress] = useState('');
  const [editingCustomer, setEditingCustomer] = useState<string | null>(null);

  // Form States - New Order & Cart
  const [selectedCustomerId, setSelectedCustomerId] = useState('');
  const [customerSearch, setCustomerSearch] = useState('');
  const [cartItems, setCartItems] = useState<{id: string, quantity: number, price?: number}[]>([]);
  const [showCart, setShowCart] = useState(false);
  const [activeOrderDetails, setActiveOrderDetails] = useState<Order | null>(null);
  const { toPDF, targetRef } = usePDF({filename: `order_${activeOrderDetails?.orderNumber || activeOrderDetails?.id?.slice(0, 4) || 'invoice'}.pdf`});
  const [discount, setDiscount] = useState<number | ''>('');
  const [paymentStatus, setPaymentStatus] = useState<'unpaid' | 'partial' | 'paid'>('unpaid');
  const [orderNotes, setOrderNotes] = useState('');
  const [selectedCategoryFilter, setSelectedCategoryFilter] = useState<string>('all');

  // Handlers - Products
  const handleImageUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement('canvas');
          let width = img.width;
          let height = img.height;
          
          // Max dimensions
          const MAX_SIZE = 800;
          if (width > height && width > MAX_SIZE) {
            height *= MAX_SIZE / width;
            width = MAX_SIZE;
          } else if (height > MAX_SIZE) {
            width *= MAX_SIZE / height;
            height = MAX_SIZE;
          }
          
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          if (ctx) {
            // Draw uncompressed image to canvas
            ctx.drawImage(img, 0, 0, width, height);
            
            // Compress image to JPEG at 70% quality
            const compressedDataUrl = canvas.toDataURL('image/jpeg', 0.7);
            
            // Further protect against huge sizes (arbitrary safety check, about ~2MB base64)
            if (compressedDataUrl.length > 3000000) {
                alert('عذراً، حجم الصورة كبير جداً حتى بعد الضغط. يرجى اختيار صورة أصغر.');
                return;
            }
            
            setProductImage(compressedDataUrl);
          }
        };
        img.src = reader.result as string;
      };
      reader.readAsDataURL(file);
    }
  };

  const handleAddProduct = (e: React.FormEvent) => {
    e.preventDefault();
    if (!productName || !productSellPrice || !productPurchasePrice) return;

    if (editingProduct) {
      setProducts(prev => prev.map(p => p.id === editingProduct ? {
        ...p,
        name: productName,
        sellPrice: parseFloat(productSellPrice) || 0,
        purchasePrice: parseFloat(productPurchasePrice) || 0,
        description: productDescription,
        image: productImage,
        categoryId: productCategory || undefined
      } : p));
      setEditingProduct(null);
    } else {
      const newProduct: Product = {
        id: crypto.randomUUID ? crypto.randomUUID() : Date.now().toString(),
        name: productName,
        sellPrice: parseFloat(productSellPrice) || 0,
        purchasePrice: parseFloat(productPurchasePrice) || 0,
        description: productDescription,
        image: productImage,
        categoryId: productCategory || undefined
      };
      setProducts(prev => [newProduct, ...prev]);
    }

    setProductName('');
    setProductSellPrice('');
    setProductPurchasePrice('');
    setProductDescription('');
    setProductImage('');
    setProductCategory('');
    setShowAddProduct(false);
  };

  const deleteProduct = (id: string) => {
    setConfirmDialog({
      isOpen: true,
      message: 'هل أنت متأكد من حذف هذا المنتج؟',
      onConfirm: () => {
        setProducts(prev => prev.filter(p => p.id !== id));
        if (editingProduct === id) {
          setEditingProduct(null);
          setProductName('');
          setProductSellPrice('');
          setProductPurchasePrice('');
          setProductDescription('');
          setProductImage('');
          setProductCategory('');
          setShowAddProduct(false);
        }
      }
    });
  };

  const editProduct = (product: Product) => {
    setEditingProduct(product.id);
    setProductName(product.name);
    setProductSellPrice(product.sellPrice.toString());
    setProductPurchasePrice(product.purchasePrice.toString());
    setProductDescription(product.description || '');
    setProductImage(product.image || '');
    setProductCategory(product.categoryId || '');
    setShowAddProduct(true);
  };

  const handleAddCategory = (e: React.FormEvent) => {
    e.preventDefault();
    if (!categoryName) return;
    
    if (editingCategory) {
      setCategories(prev => prev.map(c => c.id === editingCategory ? { ...c, name: categoryName } : c));
      setEditingCategory(null);
    } else {
      const newCategory: Category = {
        id: crypto.randomUUID ? crypto.randomUUID() : Date.now().toString(),
        name: categoryName
      };
      setCategories(prev => [...prev, newCategory]);
      // Auto-select newly created category if in product form
      setProductCategory(newCategory.id);
    }
    setCategoryName('');
  };

  const deleteCategory = (id: string) => {
    setConfirmDialog({
      isOpen: true,
      message: 'هل أنت متأكد من حذف هذه الفئة؟ سيبقى المنتج محتفظاً بتفاصيله ولكن بدون الفئة المحذوفة.',
      onConfirm: () => {
        setCategories(prev => prev.filter(c => c.id !== id));
        setProducts(prev => prev.map(p => p.categoryId === id ? { ...p, categoryId: undefined } : p));
        if (editingCategory === id) {
          setEditingCategory(null);
          setCategoryName('');
        }
      }
    });
  };

  const editCategory = (category: Category) => {
    setEditingCategory(category.id);
    setCategoryName(category.name);
  };

  // Handlers - Customers
  const handleAddCustomer = (e: React.FormEvent) => {
    e.preventDefault();
    if (!customerName || !customerPhone || !customerAddress) return;

    if (editingCustomer) {
      setCustomers(prev => prev.map(c => c.id === editingCustomer ? {
        ...c,
        name: customerName,
        phone: customerPhone,
        address: customerAddress
      } : c));
      setEditingCustomer(null);
    } else {
      const newCustomer: Customer = {
        id: crypto.randomUUID ? crypto.randomUUID() : Date.now().toString(),
        name: customerName,
        phone: customerPhone,
        address: customerAddress,
      };
      setCustomers(prev => [newCustomer, ...prev]);
    }

    setCustomerName('');
    setCustomerPhone('');
    setCustomerAddress('');
  };

  const deleteCustomer = (id: string) => {
    setConfirmDialog({
      isOpen: true,
      message: 'هل أنت متأكد من حذف هذا الزبون؟',
      onConfirm: () => {
        setCustomers(prev => prev.filter(c => c.id !== id));
        if (editingCustomer === id) {
          setEditingCustomer(null);
          setCustomerName('');
          setCustomerPhone('');
          setCustomerAddress('');
        }
      }
    });
  };

  const editCustomer = (customer: Customer) => {
    setEditingCustomer(customer.id);
    setCustomerName(customer.name);
    setCustomerPhone(customer.phone);
    setCustomerAddress(customer.address);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  // Handlers - Orders / Cart
  const toggleProduct = (id: string) => {
    setCartItems(prev => {
      const existing = prev.find(item => item.id === id);
      if (existing) {
        return prev.filter(item => item.id !== id);
      } else {
        return [...prev, { id, quantity: 1 }];
      }
    });
  };

  const updateQuantity = (id: string, delta: number) => {
    setCartItems(prev => prev.map(item => {
      if (item.id === id) {
        const newQty = Math.max(1, item.quantity + delta);
        return { ...item, quantity: newQty };
      }
      return item;
    }));
  };
  
  const removeFromCart = (id: string) => {
    setCartItems(prev => prev.filter(item => item.id !== id));
  };
  
  const clearCart = () => setCartItems([]);

  const handleCartSubmit = () => {
    const customer = customers.find(c => c.id === selectedCustomerId);
    if (!customer) {
      alert('يرجى اختيار زبون من قائمة الزبائن.');
      return;
    }
    if (cartItems.length === 0) {
      alert('السلة فارغة. يرجى إضافة منتجات.');
      return;
    }

    const cartTotalAmount = cartItems.reduce((sum, item) => {
      const p = products.find(prod => prod.id === item.id);
      return sum + ((item.price !== undefined ? item.price : p?.sellPrice || 0) * item.quantity);
    }, 0);
    const finalAmount = Math.max(0, cartTotalAmount - (parseFloat(discount.toString()) || 0));

    let finalNotes = orderNotes;
    
    // Format cart items
    const itemsDetailsList = cartItems.map(item => {
      const p = products.find(prod => prod.id === item.id);
      if (!p) return null;
      return {
        productId: p.id,
        name: p.name,
        quantity: item.quantity,
        price: item.price !== undefined ? item.price : p.sellPrice
      };
    }).filter(Boolean) as OrderItem[];

    const itemsDetailsText = itemsDetailsList.map(item => `${item.quantity}x ${item.name} (${item.quantity * item.price})`).join('\n');

    finalNotes = `المنتجات:\n${itemsDetailsText}\n---\nخصم: ${discount || 0}\nحالة الدفع: ${paymentStatus}\nملاحظات:\n${finalNotes}`.trim();

    const newOrder: Order = {
      id: crypto.randomUUID ? crypto.randomUUID() : Date.now().toString(),
      orderNumber: String(Math.floor(1000 + Math.random() * 9000)), // 4-digit order number
      customerName: customer.name,
      phone: customer.phone,
      address: customer.address,
      amount: finalAmount,
      subtotal: cartTotalAmount,
      discount: parseFloat(discount.toString()) || 0,
      paymentStatus: paymentStatus,
      items: itemsDetailsList,
      status: 'pending',
      createdAt: Date.now(),
      notes: finalNotes
    };

    setOrders(prev => [newOrder, ...prev]);
    
    // Reset order form & cart
    setSelectedCustomerId('');
    setCustomerSearch('');
    setCartItems([]);
    setDiscount('');
    setOrderNotes('');
    setPaymentStatus('unpaid');
    setShowCart(false);
    setActiveOrderDetails(newOrder);
  };

  const updateOrderStatus = (id: string, status: OrderStatus) => {
    setOrders(prev => prev.map(o => o.id === id ? { ...o, status } : o));
  };

  const deleteOrder = (id: string) => {
    setConfirmDialog({
      isOpen: true,
      message: 'هل أنت متأكد من حذف هذا الطلب؟',
      onConfirm: () => {
        setOrders(prev => prev.filter(o => o.id !== id));
      }
    });
  };

  const getStatusColor = (status: OrderStatus) => {
    switch (status) {
      case 'delivered': return 'bg-emerald-100 text-emerald-800 border-emerald-200';
      case 'pending': return 'bg-amber-100 text-amber-800 border-amber-200';
      case 'cancelled': return 'bg-red-100 text-red-800 border-red-200';
      default: return 'bg-gray-100 text-gray-800 border-gray-200';
    }
  };

  const getStatusLabel = (status: OrderStatus) => {
    switch (status) {
      case 'delivered': return 'تم التوصيل';
      case 'pending': return 'قيد التوصيل';
      case 'cancelled': return 'ملغى';
      default: return status;
    }
  };

  // Settings Handlers
  const [isUploading, setIsUploading] = useState(false);
  const [uploadProgress, setUploadProgress] = useState(0);

  const downloadBackup = () => {
    const data = { orders, products, customers, timestamp: Date.now() };
    const blob = new Blob([JSON.stringify(data)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `mandoob_backup_${new Date().toISOString().split('T')[0]}.json`;
    a.click();
    URL.revokeObjectURL(url);
  };

  const uploadBackup = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const data = JSON.parse(event.target?.result as string);
        if (data.orders && data.products && data.customers) {
          // Simulate 10 second progress
          setIsUploading(true);
          setUploadProgress(0);
          
          let progress = 0;
          const interval = setInterval(() => {
            progress += 1;
            setUploadProgress(progress);
            
            if (progress >= 100) {
              clearInterval(interval);
              setTimeout(() => {
                setOrders(data.orders);
                setProducts(data.products);
                setCustomers(data.customers);
                setIsUploading(false);
                setUploadProgress(0);
                alert('تم استعادة النسخة الاحتياطية بنجاح');
              }, 200);
            }
          }, 100); // 100 iterations * 100ms = 10,000ms = 10 seconds

        } else {
          alert('ملف النسخة الاحتياطية غير صالح');
        }
      } catch (error) {
        alert('حدث خطأ أثناء قراءة الملف');
      }
    };
    reader.readAsText(file);
    e.target.value = ''; // Reset input
  };

  const handleSetPassword = (e: React.FormEvent) => {
    e.preventDefault();
    localStorage.setItem(STORAGE_KEY_PASSWORD, newPassword);
    setPassword(newPassword);
    setNewPassword('');
    alert('تم حفظ كلمة السر بنجاح');
  };

  const handleRemovePassword = () => {
    localStorage.removeItem(STORAGE_KEY_PASSWORD);
    setPassword('');
    setIsAuthenticated(true);
  };

  const handleLogin = (e: React.FormEvent) => {
    e.preventDefault();
    if (loginPassword === password) {
      setIsAuthenticated(true);
      setLoginError('');
      setLoginPassword('');
    } else {
      setLoginError('كلمة السر غير صحيحة');
    }
  };

  // Renderers for Views
  const renderProductsTab = () => (
    <div className="space-y-6">
      {!showAddProduct && !showAddCategory ? (
        <div className="flex flex-col sm:flex-row gap-3 justify-end relative z-0">
          <button 
            onClick={() => setShowAddCategory(true)}
            className="w-full sm:w-auto bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2.5 px-5 rounded-xl transition-colors flex items-center justify-center gap-2 shadow-sm"
          >
            <Plus className="w-5 h-5" />
            إضافة فئة
          </button>
          <button 
            onClick={() => setShowAddProduct(true)}
            className="w-full sm:w-auto bg-sky-500 hover:bg-sky-600 text-white font-semibold py-2.5 px-5 rounded-xl transition-colors flex items-center justify-center gap-2 shadow-sm"
          >
            <Plus className="w-5 h-5" />
            إضافة منتج جديد
          </button>
        </div>
      ) : showAddCategory ? (
        <div className="bg-white rounded-2xl p-5 shadow-sm border border-sky-100 relative z-0">
          <div className="flex items-center justify-between mb-4">
            <h2 className="text-lg font-bold text-sky-900 flex items-center gap-2">
              <Plus className="w-5 h-5 text-sky-500" />
              إضافة فئة جديدة
            </h2>
            <button 
              onClick={() => setShowAddCategory(false)}
              className="text-gray-400 hover:text-gray-600 bg-gray-50 hover:bg-gray-100 p-1.5 rounded-lg transition-colors"
            >
              <XCircle className="w-5 h-5" />
            </button>
          </div>
          <form onSubmit={handleAddCategory} className="space-y-4">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-1 flex items-center gap-1">اسم الفئة</label>
              <input 
                type="text" required value={categoryName} onChange={(e) => setCategoryName(e.target.value)}
                className="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none transition"
                placeholder="مثال: المشروبات"
              />
            </div>
            <div className="flex gap-2 mt-2">
              <button type="submit" className="flex-1 bg-sky-500 hover:bg-sky-600 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2">
                <Plus className="w-5 h-5" />
                {editingCategory ? 'تحديث الفئة' : 'حفظ الفئة'}
              </button>
              {editingCategory && (
                <button type="button" onClick={() => { setEditingCategory(null); setCategoryName(''); }} className="px-5 bg-gray-100 hover:bg-gray-200 text-gray-600 font-semibold py-3 rounded-xl transition-colors flex items-center justify-center">
                  إلغاء
                </button>
              )}
            </div>
          </form>

          {/* Categories List */}
          <div className="mt-8 border-t border-sky-100 pt-6">
            <h3 className="text-sm font-bold text-sky-900 mb-4">الفئات المسجلة</h3>
            {categories.length === 0 ? (
              <div className="text-center py-6 bg-sky-50/50 rounded-xl border border-dashed border-sky-200">
                <p className="text-sky-700/60 font-medium text-sm">لا توجد فئات منشأة بعد.</p>
              </div>
            ) : (
              <div className="space-y-2 max-h-60 overflow-y-auto pr-2 scrollbar-hide">
                {categories.map(cat => (
                  <div key={cat.id} className="flex items-center justify-between p-3 bg-gray-50 hover:bg-sky-50 border border-gray-100 hover:border-sky-100 rounded-xl transition-colors">
                    <span className="font-bold text-sky-600 text-sm">{cat.name}</span>
                    <div className="flex gap-1">
                      <button 
                        onClick={() => editCategory(cat)}
                        className="p-2 text-sky-600 hover:bg-sky-100 rounded-lg transition-colors"
