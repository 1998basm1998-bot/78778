                          <span className="text-sky-300 print:text-sky-600 text-sm">{item.quantity}x</span>
                          <span className="text-white print:text-black font-bold ml-2">{item.price} د.ع</span>
                        </div>
                      </div>
                    )) : (
                      <div className="text-gray-400 text-sm whitespace-pre-wrap">
                        {activeOrderDetails.notes}
                      </div>
                    )}
                  </div>
                  
                  <div className="flex justify-between items-center border-t border-white/10 print:border-gray-300 pt-5 mt-5">
                    <span className="text-white print:text-black font-bold text-lg">الإجمالي الكلي</span>
                    <span className="text-3xl font-extrabold text-white print:text-black" style={{ direction: 'ltr'}}>{activeOrderDetails.amount} د.ع</span>
                  </div>
                </div>
              </div>

              {/* Actions Footer */}
              <div className="p-4 sm:p-5 border-t border-white/10 bg-[#0f172a] print:hidden space-y-3">
                <div className="grid grid-cols-2 sm:grid-cols-3 gap-3">
                  {activeOrderDetails.status !== 'delivered' && (
                    <button onClick={() => {
                        updateOrderStatus(activeOrderDetails.id, 'delivered');
                        setActiveOrderDetails({...activeOrderDetails, status: 'delivered'});
                    }} className="col-span-1 bg-[#7bc341] hover:bg-[#68a834] text-white py-3.5 rounded-xl text-sm font-bold flex items-center justify-center gap-1.5 transition-colors">
                      <CheckCircle2 className="w-5 h-5" />
                      تأكيد التسليم
                    </button>
                  )}
                  <button onClick={() => setAlertDialog({ isOpen: true, message: 'سيتم إضافة هذه الميزة لاحقاً' })} className="col-span-1 bg-[#7bc341] hover:bg-[#68a834] text-white py-3.5 rounded-xl text-sm font-bold flex items-center justify-center gap-1.5 transition-colors">
                    <Package className="w-5 h-5" />
                    تعديل الطلب
                  </button>
                  <button onClick={() => toPDF()} className={`col-span-2 sm:col-span-1 bg-[#7bc341] hover:bg-[#68a834] text-white py-3.5 rounded-xl text-sm font-bold flex items-center justify-center gap-1.5 transition-colors ${activeOrderDetails.status === 'delivered' ? 'col-span-2' : ''}`}>
                    <Download className="w-5 h-5" />
                    تصدير PDF
                  </button>
                </div>
                <button onClick={() => {
                  deleteOrder(activeOrderDetails.id);
                  setActiveOrderDetails(null);
                }} className="w-full bg-rose-500/20 hover:bg-rose-500/30 text-rose-500 py-3.5 rounded-xl text-sm font-bold flex items-center justify-center gap-2 transition-colors">
                  <Trash2 className="w-5 h-5" />
                  حذف الطلب
                </button>
              </div>

              {/* Hidden Invoice For PDF Export */}
              <div
                ref={targetRef}
                className="bg-white text-black rtl"
                style={{
                  position: 'absolute',
                  left: '-9999px',
                  top: '-9999px',
                  width: '800px',
                  padding: '40px',
                  direction: 'rtl',
                  fontFamily: 'sans-serif'
                }}
              >
                {/* Header */}
                <div className="flex justify-between items-start border-b-[3px] border-black pb-6 mb-6">
                  <div className="text-right space-y-2">
                    <h2 className="font-bold text-3xl text-gray-900 leading-tight">مخازن القمة</h2>
                    <p className="text-lg text-gray-800 font-medium">07704681211</p>
                  </div>
                  <div className="text-center font-bold">
                    <h1 className="text-3xl font-black mb-2 text-gray-900 tracking-tight">فاتورة مبيعات</h1>
                    <p className="text-lg text-gray-700 font-medium">{new Intl.DateTimeFormat('ar-SA', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(new Date(activeOrderDetails.createdAt))}</p>
                  </div>
                  <div className="text-left space-y-2">
                    <p className="text-lg font-bold text-gray-900">عميل: <span className="font-medium text-gray-800">{activeOrderDetails.customerName}</span></p>
                    <p className="text-lg font-bold text-gray-900">الرقم: <span className="font-medium text-gray-800">{activeOrderDetails.orderNumber || activeOrderDetails.id.slice(0,4)}</span></p>
                  </div>
                </div>

                {/* Table */}
                <table className="w-full mb-8 border-collapse border-2 border-black" style={{ borderCollapse: 'collapse' }}>
                  <thead className="bg-gray-50 border-b-2 border-black">
                    <tr>
                      <th className="border border-black p-3 text-center w-32 text-sm font-bold text-gray-900">الاجمالي</th>
                      <th className="border border-black p-3 text-center w-32 text-sm font-bold text-gray-900">السعر</th>
                      <th className="border border-black p-3 text-center w-24 text-sm font-bold text-gray-900">الكمية</th>
                      <th className="border border-black p-3 text-right text-sm font-bold text-gray-900">الصنف</th>
                      <th className="border border-black p-3 text-center w-12 text-sm font-bold text-gray-900">ت</th>
                    </tr>
                  </thead>
                  <tbody>
                    {activeOrderDetails.items && activeOrderDetails.items.length > 0 ? (
                      activeOrderDetails.items.map((item, idx) => (
                        <tr key={idx} className="border-b border-black last:border-b-0">
                          <td className="border border-black p-3 text-center font-bold text-gray-900">{(item.price * item.quantity).toLocaleString()}</td>
                          <td className="border border-black p-3 text-center font-medium text-gray-900">{item.price.toLocaleString()}</td>
                          <td className="border border-black p-3 text-center font-medium text-gray-900">{item.quantity}</td>
                          <td className="border border-black p-3 text-right font-medium text-gray-900">{item.name}</td>
                          <td className="border border-black p-3 text-center font-medium text-gray-900">{idx + 1}</td>
                        </tr>
                      ))
                    ) : (
                      <tr>
                        <td colSpan={5} className="border border-black p-4 text-center text-gray-700 font-medium">
                          {activeOrderDetails.notes}
                        </td>
                      </tr>
                    )}
                  </tbody>
                </table>

                {/* Footer Totals */}
                <div className="w-1/2 ml-auto mb-8 p-5 border-2 border-black rounded-lg bg-gray-50">
                  <div className="flex justify-between font-bold text-lg mb-3 text-gray-800">
                    <span>المجموع الفرعي:</span>
                    <span>{(activeOrderDetails.subtotal || activeOrderDetails.amount).toLocaleString()}</span>
                  </div>
                  {activeOrderDetails.discount && activeOrderDetails.discount > 0 ? (
                    <div className="flex justify-between font-bold text-lg mb-3 text-gray-800">
                      <span>الخصم:</span>
                      <span>{activeOrderDetails.discount.toLocaleString()}</span>
                    </div>
                  ) : null}
                  <div className="flex justify-between font-black text-2xl border-t-2 border-black pt-4 mb-4 text-gray-900">
                    <span>اجمالي الفاتورة:</span>
                    <span>{activeOrderDetails.amount.toLocaleString()}</span>
                  </div>
                  <div className="flex justify-between font-medium flex-wrap text-lg mb-3 text-gray-800">
                    <span className="font-bold">المبلغ المدفوع:</span>
                    <span>{activeOrderDetails.paymentStatus === 'paid' ? activeOrderDetails.amount.toLocaleString() : '0'}</span>
                  </div>
                  <div className="flex justify-between font-medium flex-wrap text-lg mb-3 text-gray-800">
                    <span className="font-bold">المبلغ المتبقي:</span>
                    <span>{activeOrderDetails.paymentStatus === 'paid' ? '0' : activeOrderDetails.amount.toLocaleString()}</span>
                  </div>
                  <div className="flex justify-between font-medium flex-wrap text-lg text-gray-800">
                    <span className="font-bold">حالة الدفع:</span>
                    <span>{activeOrderDetails.paymentStatus === 'paid' ? 'مدفوع' : activeOrderDetails.paymentStatus === 'partial' ? 'مدفوع جزئياً' : 'غير مدفوع'}</span>
                  </div>
                </div>

                <div className="mt-12 text-center text-sm font-medium text-gray-500 border-t border-gray-200 pt-6">
                  تم إنشاء هذه الفاتورة من تطبيق مندوب Urux | للتواصل: 07838584311
                </div>
              </div>

            </div>
          </div>
        )}
        {/* Alert Modal */}
        {alertDialog && (
          <div className="fixed inset-0 z-[100] bg-black/60 backdrop-blur-sm flex items-center justify-center p-4">
            <div className="bg-white rounded-2xl max-w-sm w-full p-6 shadow-2xl animate-in zoom-in-95 duration-200">
              <div className="w-12 h-12 bg-sky-100 text-sky-500 rounded-full flex items-center justify-center mb-4 mx-auto">
                <CheckCircle className="w-6 h-6" />
              </div>
              <p className="text-center text-gray-800 font-bold mb-6 text-lg">{alertDialog.message}</p>
              <button 
                onClick={() => setAlertDialog(null)}
                className="w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 px-4 rounded-xl transition-colors"
                type="button"
              >
                حسناً
              </button>
            </div>
          </div>
        )}

        {/* Confirm Modal */}
        {confirmDialog && (
          <div className="fixed inset-0 z-[100] bg-black/60 backdrop-blur-sm flex items-center justify-center p-4">
            <div className="bg-white rounded-2xl max-w-sm w-full p-6 shadow-2xl animate-in zoom-in-95 duration-200">
              <div className="w-12 h-12 bg-red-100 text-red-500 rounded-full flex items-center justify-center mb-4 mx-auto">
                <Trash2 className="w-6 h-6" />
              </div>
              <p className="text-center text-gray-800 font-bold mb-6 text-lg">{confirmDialog.message}</p>
              <div className="flex gap-3">
                <button 
                  onClick={() => {
                    confirmDialog.onConfirm();
                    setConfirmDialog(null);
                  }}
                  className="flex-1 bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-4 rounded-xl transition-colors"
                  type="button"
                >
                  نعم، تأكيد
                </button>
                <button 
                  onClick={() => setConfirmDialog(null)}
                  className="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 font-bold py-3 px-4 rounded-xl transition-colors"
                  type="button"
                >
                  إلغاء
                </button>
              </div>
            </div>
          </div>
        )}
      </main>

      {/* Fixed Bottom Navigation (التبويبات الثابتة) */}
      <nav className="fixed bottom-0 left-0 right-0 bg-white border-t border-sky-100 shadow-[0_-4px_20px_rgba(0,0,0,0.05)] z-50">
        <div className="max-w-3xl mx-auto px-1 h-16 flex justify-around items-center">
          
          <button 
            onClick={() => setActiveTab('products')} 
            className={`flex flex-col items-center justify-center w-full h-full transition-all duration-200 border-t-2 relative ${activeTab === 'products' ? 'text-sky-600 border-sky-500' : 'text-gray-400 border-transparent hover:text-sky-500'}`}
          >
            {activeTab === 'products' && <span className="absolute inset-x-0 top-0 h-full bg-sky-50/50 -z-10 rounded-t-lg" />}
            <Package className={`w-5 h-5 mb-1 ${activeTab === 'products' ? 'fill-sky-100' : ''}`} />
            <span className="text-xs font-bold">المنتجات</span>
          </button>

          <button 
            onClick={() => setActiveTab('customers')} 
            className={`flex flex-col items-center justify-center w-full h-full transition-all duration-200 border-t-2 relative ${activeTab === 'customers' ? 'text-sky-600 border-sky-500' : 'text-gray-400 border-transparent hover:text-sky-500'}`}
          >
            {activeTab === 'customers' && <span className="absolute inset-x-0 top-0 h-full bg-sky-50/50 -z-10 rounded-t-lg" />}
            <Users className={`w-5 h-5 mb-1 ${activeTab === 'customers' ? 'fill-sky-100' : ''}`} />
            <span className="text-xs font-bold">الزبائن</span>
          </button>

          <button 
            onClick={() => setActiveTab('new_order')} 
            className={`flex flex-col items-center justify-center w-full h-full transition-all duration-200 border-t-2 relative ${activeTab === 'new_order' ? 'text-sky-600 border-sky-500' : 'text-gray-400 border-transparent hover:text-sky-500'}`}
          >
            {activeTab === 'new_order' && <span className="absolute inset-x-0 top-0 h-full bg-sky-50/50 -z-10 rounded-t-lg" />}
            <PlusCircle className={`w-5 h-5 mb-1 ${activeTab === 'new_order' ? 'fill-sky-100' : ''}`} />
            <span className="text-xs font-bold">طلب جديد</span>
          </button>

        </div>
      </nav>

      {/* iOS Install Prompt Modal */}
      {showIosInstructionsModal && (
        <div className="fixed inset-0 z-[100] bg-black/60 flex items-center justify-center p-4 backdrop-blur-sm animate-in fade-in duration-300">
          <div className="bg-white text-gray-900 rounded-3xl w-full max-w-sm overflow-hidden shadow-2xl relative">
             <div className="p-6 text-center">
                <div className="w-16 h-16 bg-sky-100 text-sky-500 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-inner">
                   <Download className="w-8 h-8" />
                </div>
                <h3 className="text-xl font-bold mb-2">تثبيت التطبيق على الآيفون</h3>
                <p className="text-gray-600 mb-6 text-sm leading-relaxed">
                  لتثبيت التطبيق للحصول على أفضل تجربة واستخدامه بدون إنترنت، اتبع الخطوات التالية في متصفح سفاري (Safari):
                </p>
                <div className="text-right space-y-4 bg-gray-50 p-4 rounded-2xl border border-gray-100 shadow-sm">
                   <div className="flex items-center gap-3">
                      <div className="w-8 h-8 rounded-full bg-sky-500 text-white flex items-center justify-center font-bold text-sm shrink-0">1</div>
                      <p className="text-sm">اضغط على زر المشاركة (Share) في شريط المتصفح أسفل الشاشة أو أعلاها.</p>
                   </div>
                   <div className="flex items-center gap-3">
                      <div className="w-8 h-8 rounded-full bg-sky-500 text-white flex items-center justify-center font-bold text-sm shrink-0">2</div>
                      <p className="text-sm">اسحب للأعلى واختر <strong>"إضافة إلى الصفحة الرئيسية"</strong> (Add to Home Screen).</p>
                   </div>
                   <div className="flex items-center gap-3">
                      <div className="w-8 h-8 rounded-full bg-sky-500 text-white flex items-center justify-center font-bold text-sm shrink-0">3</div>
                      <p className="text-sm">اضغط على <strong>"إضافة"</strong> (Add) في أعلى الشاشة.</p>
                   </div>
                </div>
             </div>
             <div className="p-4 bg-gray-50 border-t border-gray-100 border-dashed">
                <button 
                  onClick={() => setShowIosInstructionsModal(false)}
                  className="w-full py-3 bg-gray-900 hover:bg-gray-800 text-white rounded-xl font-bold transition-colors"
                >
                  فهمت ذلك، إغلاق
                </button>
             </div>
          </div>
        </div>
      )}
    </div>
  );
}
